SA_PASSWORD=YourStrongPasswordHere!
APP_DB_USER=app_reader
APP_DB_PASSWORD=ChooseAnotherStrongPasswordHere!
SQL_DATABASE=IndustrialAssets
MQTT_APP_USERNAME=unity_client
MQTT_APP_PASSWORD=ChooseMqttPasswordHere!
MQTT_ACL_DB_USER=app_reader
MQTT_APP_TOPIC_PREFIX=mx
# Optional: override where ACL/passwd files are written.
# Absolute path recommended for remote hosts with pre-existing mounts.
# Example (Linux): /home/donb/mqtt-project/config/auth
# Example (Windows): C:\\mqtt-project\\config\\auth
MQTT_AUTH_DIR=
# Optional: override where TLS cert files are read from.
# Expected files: ca.crt, server.crt, server.key
# Example (Linux): /home/donb/mqtt-project/config/certs
MQTT_CERT_DIR=
MQTT_HOST_PORT=1884
MQTT_WS_HOST_PORT=9001
MQTT_TLS_HOST_PORT=8883
MQTT_WSS_HOST_PORT=9443
